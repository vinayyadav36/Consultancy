# ─────────────────────────────────────────────
# Shree Nandi Marketing Services — Environment
# ─────────────────────────────────────────────

# Frontend environment variables
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Controls whether /admin route is accessible (set to true in production)
VITE_ENABLE_ADMIN=true

# Backend API base URL (set to your deployed backend URL)
VITE_API_BASE=http://localhost:3001

# Stripe publishable key (for client-side checkout)
VITE_STRIPE_PUBLISHABLE=pk_test_your_key_here

# ─────────────────────────────────────────────
# Backend environment variables (backend/.env)
# ─────────────────────────────────────────────
# DATABASE_URL=postgresql://snms:snms_secret@localhost:5432/shiva_marketing
# JWT_SECRET=your-secure-jwt-secret-min-32-chars
# STRIPE_SECRET_KEY=sk_test_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (SMTP / Nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# CONTACT_EMAIL=contact@shreenadimarketing.com

# AI / OpenAI compatible provider
# AI_API_KEY=sk-your-openai-key
# AI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-3.5-turbo

# Frontend URL (for CORS)
# FRONTEND_URL=http://localhost:5173
