// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Visitor {
  id        String   @id @default(uuid())
  ip        String
  day       String   // YYYY-MM-DD
  userAgent String?
  path      String?
  createdAt DateTime @default(now())

  @@unique([ip, day])
  @@index([createdAt])
  @@index([ip])
  @@index([day])
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  role         String     @default("admin")
  name         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  price       Float
  features    String[] // JSON array of feature strings
  badge       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]

  @@index([slug])
  @@index([createdAt])
}

model Order {
  id            String   @id @default(uuid())
  orderId       String   @unique
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  customerName  String
  customerEmail String
  customerPhone String?
  company       String?
  gst           String?
  amount        Float
  currency      String   @default("INR")
  status        String   @default("pending") // pending | paid | failed | fulfilled
  paymentMethod String?
  stripeId      String?
  npsScore      Int?
  npsComment    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([customerEmail])
}

model Certification {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  issuer      String
  year        Int
  description String
  url         String?
  icon        String?
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([createdAt])
}

model Brochure {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  subtitle    String?
  sections    Json     // Array of {heading, content}
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([entity])
}
